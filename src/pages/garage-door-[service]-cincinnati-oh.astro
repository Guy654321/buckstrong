---
import { REPAIR_SERVICE_PAGES } from '../data/repair-service-pages';

export function getStaticPaths() {
  return REPAIR_SERVICE_PAGES.map((service) => ({
    params: { service: service.slug }
  }));
}

const { service } = Astro.params;

if (!service) {
  return Astro.redirect('/cincinnati-oh/garage-door-maintenance', 301);
}

return Astro.redirect(`/cincinnati-oh/garage-door-${service}`, 301);
---
