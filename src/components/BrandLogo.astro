---
export interface Props {
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  priority?: boolean;
  alt?: string;
  itemprop?: string;
  ariaHidden?: boolean;
}

const {
  size = 'md',
  class: className = '',
  priority = false,
  alt = 'Buck Strong Garage Doors logo',
  itemprop,
  ariaHidden = false
} = Astro.props;

const sizeConfig = {
  sm: {
    width: 120,
    height: 120
  },
  md: {
    width: 168,
    height: 168
  },
  lg: {
    width: 240,
    height: 240
  }
} as const;

const { width: intrinsicWidth, height: intrinsicHeight } = sizeConfig[size];
const logoSrc = '/images/ohio%20logo.png';

const loading = priority ? 'eager' : 'lazy';
const decoding = priority ? 'sync' : 'async';
const fetchPriority = priority ? 'high' : 'auto';
---
<img
  src={logoSrc}
  alt={alt}
  width={intrinsicWidth}
  height={intrinsicHeight}
  class={`w-auto ${className}`.trim()}
  loading={loading}
  decoding={decoding}
  fetchpriority={fetchPriority}
  itemprop={itemprop}
  aria-hidden={ariaHidden ? 'true' : undefined}
/>
