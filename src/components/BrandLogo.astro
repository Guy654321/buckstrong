---
import { getImage } from 'astro:assets';
import logoSource from '../assets/images/buck-strong-logo.png';

export interface Props {
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  priority?: boolean;
  alt?: string;
  itemprop?: string;
  ariaHidden?: boolean;
}

const {
  size = 'md',
  class: className = '',
  priority = false,
  alt = 'Buck Strong Garage Doors logo',
  itemprop,
  ariaHidden = false
} = Astro.props;

const sizeConfig = {
  sm: {
    widths: [72, 96, 120],
    sizes: '(max-width: 640px) 96px, 120px'
  },
  md: {
    widths: [96, 120, 144, 168],
    sizes: '(max-width: 640px) 108px, (max-width: 1024px) 144px, 168px'
  },
  lg: {
    widths: [120, 144, 192, 240],
    sizes: '(max-width: 768px) 144px, (max-width: 1280px) 192px, 240px'
  }
} as const;

const { widths, sizes } = sizeConfig[size];
const responsiveWidths = [...widths];
const intrinsicWidth = responsiveWidths.at(-1) ?? 240;
const intrinsicHeight = intrinsicWidth;

const loading = priority ? 'eager' : 'lazy';
const decoding = priority ? 'sync' : 'async';
const fetchPriority = priority ? 'high' : 'auto';

const [logoAvif, logoWebp, logoPng] = await Promise.all([
  getImage({ src: logoSource, widths: responsiveWidths, format: 'avif', quality: 36 }),
  getImage({ src: logoSource, widths: responsiveWidths, format: 'webp', quality: 55 }),
  getImage({ src: logoSource, widths: responsiveWidths, format: 'png' })
]);

const logoAvifSrcSet = logoAvif.srcSet?.attribute ?? undefined;
const logoWebpSrcSet = logoWebp.srcSet?.attribute ?? undefined;
const logoPngSrcSet = logoPng.srcSet?.attribute ?? undefined;
const logoFallbackSrc = logoPng.src ?? logoSource.src;
---
<picture>
  {logoAvifSrcSet && <source srcset={logoAvifSrcSet} sizes={sizes} type="image/avif" />}
  {logoWebpSrcSet && <source srcset={logoWebpSrcSet} sizes={sizes} type="image/webp" />}
  <img
    src={logoFallbackSrc}
    srcset={logoPngSrcSet}
    sizes={sizes}
    alt={alt}
    width={intrinsicWidth}
    height={intrinsicHeight}
    class={`w-auto ${className}`.trim()}
    loading={loading}
    decoding={decoding}
    fetchpriority={fetchPriority}
    itemprop={itemprop}
    aria-hidden={ariaHidden ? 'true' : undefined}
  />
</picture>
